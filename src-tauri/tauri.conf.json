{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "simple-2fa-next",
  "version": "0.1.0",
  "identifier": "com.niko.simple-2fa-next",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "simple-2fa-next",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "YOUR_PUBLIC_KEY_FROM_STEP_10.1",
      "endpoints": [
        "https://github.com/YOUR_USER/simple-2fa-next/releases/latest/download/latest.json"
      ]
    }
  }
}
